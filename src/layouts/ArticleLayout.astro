---
import BaseLayout from './BaseLayout.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  date?: Date;
  keywords?: string[];
  headings?: Heading[];
  canonicalUrl?: string;
  jsonLd?: string;
  heroImage?: {
    url: string;
    alt: string;
    photographer: string;
    photographerUrl: string;
    unsplashUrl: string;
  } | null;
}

const {
  title,
  description,
  date,
  keywords,
  headings = [],
  canonicalUrl,
  jsonLd,
  heroImage,
} = Astro.props;

// Filter to h2 and h3 for TOC
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const hasToc = tocHeadings.length > 0;
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl}>

  {jsonLd && <Fragment slot="head" set:html={`<script type="application/ld+json">${jsonLd}</script>`} />}

  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10 lg:py-14">

    <!-- Hero image -->
    {heroImage ? (
      <figure class="w-full mb-6">
        <div class="w-full overflow-hidden rounded-xl border border-white/[0.06]" style="aspect-ratio: 16/7; max-height: 420px;">
          <img
            src={heroImage.url}
            alt={heroImage.alt}
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
        <figcaption class="mt-2 text-xs text-gray-600 text-right">
          Photo by <a href={heroImage.photographerUrl} target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-400">{heroImage.photographer}</a> on <a href={heroImage.unsplashUrl} target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-400">Unsplash</a>
        </figcaption>
      </figure>
    ) : (
      <div class="w-full bg-[#161b26] rounded-xl mb-8 overflow-hidden border border-white/[0.06]" style="aspect-ratio: 16/7; max-height: 420px;">
        <div class="w-full h-full flex items-center justify-center text-gray-600 text-sm font-medium bg-gradient-to-br from-[#161b26] to-[#0f1117]">
          Article Image
        </div>
      </div>
    )}

    <!-- Layout: article + sidebar -->
    <div class={hasToc ? 'lg:grid lg:grid-cols-[1fr_240px] lg:gap-12' : ''}>

      <!-- Article body -->
      <article class="min-w-0">
        <header class="mb-8">
          <h1 class="text-3xl sm:text-4xl font-display text-gray-100 leading-tight mb-4">{title}</h1>
          {description && (
            <p class="text-lg sm:text-xl text-gray-400 leading-relaxed">{description}</p>
          )}
          <div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-gray-500">
            <div class="flex items-center gap-2">
              <div class="w-7 h-7 rounded-full bg-emerald-500/20 flex items-center justify-center text-xs font-bold text-emerald-400">A</div>
              <span class="font-medium text-gray-300">By Ava</span>
            </div>
            <span class="text-gray-700">|</span>
            {date && (
              <time datetime={date.toISOString()}>
                Updated {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            )}
          </div>
        </header>

        <!-- Top Pick slot (injected by article page) -->
        {Astro.slots.has('top-pick') && (
          <div class="not-prose my-8">
            <slot name="top-pick" />
          </div>
        )}

        <div class="prose prose-lg prose-dark max-w-none prose-headings:font-display prose-headings:text-gray-100 prose-h2:text-3xl prose-h2:mt-14 prose-h2:mb-5 prose-a:text-emerald-400 prose-a:font-medium hover:prose-a:text-emerald-300 prose-strong:text-gray-200 prose-table:text-sm prose-hr:border-white/[0.08] prose-blockquote:border-emerald-500">
          <slot />
        </div>
      </article>

      <!-- Sticky TOC sidebar (desktop only) -->
      {hasToc && (
        <aside class="hidden lg:block">
          <div class="sticky top-20">
            <div class="bg-[#161b26] border border-white/[0.08] rounded-lg p-4">
              <p class="text-xs font-semibold text-emerald-400 uppercase tracking-wider mb-3">On this page</p>
              <nav aria-label="Table of contents">
                <ul class="space-y-1">
                  {tocHeadings.map(h => (
                    <li class={h.depth === 3 ? 'pl-3' : ''}>
                      <a
                        href={`#${h.slug}`}
                        class="block text-sm text-gray-400 hover:text-emerald-400 py-0.5 transition-colors leading-snug"
                      >
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          </div>
        </aside>
      )}

    </div>
  </div>
</BaseLayout>
