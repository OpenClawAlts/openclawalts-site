---
import BaseLayout from './BaseLayout.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  date?: Date;
  keywords?: string[];
  headings?: Heading[];
  canonicalUrl?: string;
  jsonLd?: string;
  heroImage?: {
    url: string;
    alt: string;
    photographer: string;
    photographerUrl: string;
    unsplashUrl: string;
  } | null;
}

const {
  title,
  description,
  date,
  keywords,
  headings = [],
  canonicalUrl,
  jsonLd,
  heroImage,
} = Astro.props;

// Filter to h2 and h3 for TOC
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const hasToc = tocHeadings.length > 0;
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl}>

  {jsonLd && <Fragment slot="head" set:html={`<script type="application/ld+json">${jsonLd}</script>`} />}

  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10 lg:py-14">

    <!-- Hero image -->
    {heroImage ? (
      <figure class="w-full mb-6">
        <div class="w-full overflow-hidden rounded-xl relative" style="aspect-ratio: 16/7; max-height: 420px;">
          <img
            src={heroImage.url}
            alt={heroImage.alt}
            class="w-full h-full object-cover"
            loading="eager"
          />
          <!-- Gradient overlay on bottom half -->
          <div class="absolute inset-0" style="background: linear-gradient(to bottom, transparent 50%, rgba(15,17,23,0.9) 100%); pointer-events: none;"></div>
        </div>
        <figcaption class="mt-2 text-xs text-right" style="color: #475569;">
          Photo by <a href={heroImage.photographerUrl} target="_blank" rel="noopener noreferrer" class="underline" style="color: #475569; transition: color 0.2s;" onmouseover="this.style.color='#00d4aa'" onmouseout="this.style.color='#475569'">{heroImage.photographer}</a> on <a href={heroImage.unsplashUrl} target="_blank" rel="noopener noreferrer" class="underline" style="color: #475569; transition: color 0.2s;" onmouseover="this.style.color='#00d4aa'" onmouseout="this.style.color='#475569'">Unsplash</a>
        </figcaption>
      </figure>
    ) : (
      <div class="w-full rounded-xl mb-8 overflow-hidden" style="aspect-ratio: 16/7; max-height: 420px; background: linear-gradient(135deg, #1e293b, #0f172a);">
        <div class="w-full h-full flex items-center justify-center text-sm font-medium" style="color: #475569;">
          Article Image
        </div>
      </div>
    )}

    <!-- Layout: article + sidebar -->
    <div class={hasToc ? 'lg:grid lg:grid-cols-[1fr_240px] lg:gap-12' : ''}>

      <!-- Article body -->
      <article class="min-w-0">
        <header class="mb-8">
          <h1 style="font-family: 'Fraunces', serif; font-size: clamp(1.875rem, 4vw, 2.5rem); font-weight: 900; color: #f1f5f9; line-height: 1.15; margin-bottom: 1rem;">{title}</h1>
          {description && (
            <p class="text-lg sm:text-xl leading-relaxed" style="color: #94a3b8;">{description}</p>
          )}
          <div class="mt-4 flex flex-wrap items-center gap-3 text-sm" style="color: #64748b;">
            <!-- Avatar + byline -->
            <div class="flex items-center gap-2">
              <div style="width: 32px; height: 32px; border-radius: 50%; background: #00d4aa; color: #0f1117; font-weight: 700; font-size: 0.75rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                A
              </div>
              <span style="font-weight: 500; color: #cbd5e1;">By Ava</span>
            </div>
            <span style="color: #334155;">|</span>
            {date && (
              <time datetime={date.toISOString()} style="color: #64748b;">
                Updated {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            )}
          </div>
        </header>

        <!-- Top Pick slot (injected by article page) -->
        {Astro.slots.has('top-pick') && (
          <div class="not-prose my-8">
            <slot name="top-pick" />
          </div>
        )}

        <div class="prose prose-lg prose-invert max-w-none
          prose-headings:font-['Fraunces']
          prose-h2:text-3xl prose-h2:font-bold prose-h2:mt-14 prose-h2:mb-5
          prose-a:text-[#00d4aa]
          prose-strong:text-white
          prose-table:text-sm
          prose-th:bg-[#1a1f2e]
          prose-th:text-[#94a3b8]
          prose-hr:border-white/10
          prose-blockquote:border-[#00d4aa]"
          style="color: #cbd5e1;">
          <slot />
        </div>
      </article>

      <!-- Sticky TOC sidebar (desktop only) -->
      {hasToc && (
        <aside class="hidden lg:block">
          <div class="sticky top-20">
            <div class="rounded-lg p-4" style="background: #1a1f2e; border: 1px solid rgba(255,255,255,0.08);">
              <p class="text-xs font-semibold uppercase tracking-wider mb-3" style="color: #475569;">On this page</p>
              <nav aria-label="Table of contents">
                <ul class="space-y-1">
                  {tocHeadings.map(h => (
                    <li class={h.depth === 3 ? 'pl-3' : ''}>
                      <a
                        href={`#${h.slug}`}
                        class="block text-sm py-0.5 leading-snug transition-colors"
                        style="color: #94a3b8; text-decoration: none;"
                        onmouseover="this.style.color='#00d4aa'" onmouseout="this.style.color='#94a3b8'"
                      >
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          </div>
        </aside>
      )}

    </div>
  </div>
</BaseLayout>
