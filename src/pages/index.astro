---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = true;

const articles = await getCollection('articles');
const sorted = articles.sort((a, b) => {
  const da = a.data.date?.getTime() ?? 0;
  const db = b.data.date?.getTime() ?? 0;
  return db - da;
});

const featured = sorted[0];
const rest = sorted.slice(1);

// Collect all unique tags from all articles
const allTags = [...new Set(articles.flatMap(a => a.data.keywords ?? []))].slice(0, 12);
---

<BaseLayout
  title="OpenClaw Alt"
  description="Independent reviews of AI automation tools. Honest comparisons to help you choose the right platform."
>
  <!-- Hero -->
  <section style="border-bottom: 1px solid rgba(255,255,255,0.06);">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
      <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: #00d4aa;">Independent Reviews</p>
      <h1 style="font-family: 'Fraunces', serif; font-size: clamp(2.25rem, 5vw, 3.5rem); font-weight: 900; color: #f1f5f9; line-height: 1.1; margin-bottom: 1.25rem; max-width: 36rem;">
        Cut through the <span style="color: #00d4aa;">noise</span> in AI automation.
      </h1>
      <p class="text-lg sm:text-xl leading-relaxed max-w-xl" style="color: #94a3b8;">
        We test the tools, skip the marketing, and tell you what actually works.
        <span style="color: #64748b;"> Written by practitioners, not content farms.</span>
      </p>
      <div class="mt-8">
        <a href="#articles" style="display: inline-block; padding: 0.75rem 1.75rem; background: #00d4aa; color: #0f1117; font-size: 0.9375rem; font-weight: 700; border-radius: 4px; text-decoration: none; transition: opacity 0.2s;"
          onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">
          Browse All Reviews →
        </a>
      </div>
    </div>
  </section>

  <!-- Articles -->
  <section id="articles" class="max-w-5xl mx-auto px-4 sm:px-6 py-12">

    <!-- Tag filter pills -->
    {allTags.length > 0 && (
      <div class="mb-8">
        <div id="tag-pills" class="flex flex-wrap gap-2">
          {allTags.map(tag => (
            <button
              data-tag={tag}
              class="px-3 py-1 rounded-full text-xs font-medium cursor-pointer"
              style="background: #1a1f2e; color: #64748b; border: 1px solid rgba(255,255,255,0.08); transition: all 0.15s ease;"
            >
              {tag}
            </button>
          ))}
        </div>
      </div>
    )}

    {featured && (
      <div class="mb-10">
        <p class="text-xs font-semibold uppercase tracking-wider mb-4" style="color: #475569;">Featured</p>
        <div data-article-card data-keywords={featured.data.keywords?.join(',') ?? ''}>
          <a
            href={`/articles/${featured.id}`}
            class="group block rounded-xl p-6 sm:p-8 transition-all"
            style="background: #1a1f2e; border: 1px solid rgba(255,255,255,0.08); text-decoration: none;"
            onmouseover="this.style.borderColor='rgba(0,212,170,0.2)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'"
          >
            <div class="flex flex-col sm:flex-row sm:items-start gap-6">
              <!-- Thumbnail placeholder -->
              <div class="shrink-0 w-full sm:w-[280px] h-44 rounded-lg flex items-center justify-center text-xs font-medium overflow-hidden" style="background: linear-gradient(135deg, #1e293b, #0f172a); color: #334155; border: 1px solid rgba(255,255,255,0.06);">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: #334155;">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                  <circle cx="8.5" cy="8.5" r="1.5"></circle>
                  <polyline points="21 15 16 10 5 21"></polyline>
                </svg>
              </div>
              <!-- Content -->
              <div class="flex-1 min-w-0">
                <h2 style="font-family: 'Fraunces', serif; font-size: clamp(1.375rem, 3vw, 1.875rem); font-weight: 700; color: #f1f5f9; line-height: 1.25; margin-bottom: 0.75rem; transition: color 0.2s;" class="group-hover:text-[#00d4aa]">
                  {featured.data.title}
                </h2>
                {featured.data.description && (
                  <p class="text-base leading-relaxed mb-4" style="color: #64748b;">{featured.data.description}</p>
                )}
                <div class="flex flex-wrap items-center gap-3 text-sm" style="color: #475569;">
                  {featured.data.date && (
                    <time datetime={featured.data.date.toISOString()}>
                      {featured.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                  )}
                  {featured.data.keywords && featured.data.keywords.slice(0, 3).map(kw => (
                    <span class="px-2 py-0.5 rounded text-xs" style="background: rgba(255,255,255,0.05); color: #64748b;">{kw}</span>
                  ))}
                </div>
                <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold" style="color: #00d4aa;">
                  Read →
                </span>
              </div>
            </div>
          </a>
        </div>
      </div>
    )}

    {rest.length > 0 && (
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider mb-4" style="color: #475569;">More Articles</p>
        <div class="grid sm:grid-cols-2 gap-5">
          {rest.map(article => (
            <div data-article-card data-keywords={article.data.keywords?.join(',') ?? ''}>
              <a
                href={`/articles/${article.id}`}
                class="group block rounded-xl p-5 transition-all"
                style="background: #1a1f2e; border: 1px solid rgba(255,255,255,0.08); text-decoration: none;"
                onmouseover="this.style.borderColor='rgba(0,212,170,0.2)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'"
              >
                <div class="flex items-start gap-4">
                  <!-- Thumbnail placeholder -->
                  <div class="shrink-0 w-24 h-20 rounded-lg flex items-center justify-center overflow-hidden" style="background: linear-gradient(135deg, #1e293b, #0f172a); border: 1px solid rgba(255,255,255,0.06);">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: #334155;">
                      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                      <circle cx="8.5" cy="8.5" r="1.5"></circle>
                      <polyline points="21 15 16 10 5 21"></polyline>
                    </svg>
                  </div>
                  <!-- Content -->
                  <div class="flex-1 min-w-0">
                    <h3 class="text-lg font-bold leading-snug mb-2 transition-colors group-hover:text-[#00d4aa]" style="color: #f1f5f9; font-family: 'Fraunces', serif;">
                      {article.data.title}
                    </h3>
                    {article.data.description && (
                      <p class="text-sm leading-relaxed line-clamp-2" style="color: #64748b;">{article.data.description}</p>
                    )}
                    {article.data.date && (
                      <p class="mt-2 text-xs" style="color: #475569;">
                        {article.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                      </p>
                    )}
                  </div>
                </div>
              </a>
            </div>
          ))}
        </div>
      </div>
    )}

    {articles.length === 0 && (
      <p style="color: #64748b;">No articles yet. Check back soon.</p>
    )}

  </section>
</BaseLayout>

<script>
  const ACTIVE_STYLE = {
    background: 'rgba(52,211,153,0.15)',
    borderColor: 'rgba(52,211,153,0.4)',
    color: '#34d399',
  };
  const INACTIVE_STYLE = {
    background: '#1a1f2e',
    borderColor: 'rgba(255,255,255,0.08)',
    color: '#64748b',
  };

  let activeTag: string | null = null;

  function applyPillStyle(btn: HTMLButtonElement, active: boolean) {
    const s = active ? ACTIVE_STYLE : INACTIVE_STYLE;
    btn.style.background = s.background;
    btn.style.borderColor = s.borderColor;
    btn.style.color = s.color;
  }

  function filterCards(tag: string | null) {
    const cards = document.querySelectorAll<HTMLElement>('[data-article-card]');
    cards.forEach(card => {
      if (!tag) {
        card.style.display = '';
        return;
      }
      const keywords = (card.dataset.keywords ?? '').toLowerCase().split(',').map(k => k.trim());
      card.style.display = keywords.includes(tag.toLowerCase()) ? '' : 'none';
    });
  }

  document.querySelectorAll<HTMLButtonElement>('#tag-pills button[data-tag]').forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag ?? '';
      if (activeTag === tag) {
        // deselect — show all
        activeTag = null;
        applyPillStyle(btn, false);
      } else {
        // deselect previous
        if (activeTag) {
          const prev = document.querySelector<HTMLButtonElement>(`#tag-pills button[data-tag="${activeTag}"]`);
          if (prev) applyPillStyle(prev, false);
        }
        activeTag = tag;
        applyPillStyle(btn, true);
      }
      filterCards(activeTag);
    });
  });
</script>
