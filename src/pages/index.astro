---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = true;

const articles = await getCollection('articles');
const sorted = articles.sort((a, b) => {
  const da = a.data.date?.getTime() ?? 0;
  const db = b.data.date?.getTime() ?? 0;
  return db - da;
});

const featured = sorted[0];
const rest = sorted.slice(1);

// Collect all unique keywords across articles for the filter row
const allKeywords = [...new Set(articles.flatMap(a => a.data.keywords ?? []))];
---

<BaseLayout
  title="OpenClaw Alt"
  description="Independent reviews of AI automation tools. Honest comparisons to help you choose the right platform."
>
  <!-- Hero -->
  <section class="border-b border-white/[0.06]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
      <p class="text-emerald-400 text-sm font-semibold uppercase tracking-widest mb-4">Independent Reviews</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display text-gray-100 leading-[1.1] mb-6 max-w-3xl">
        Cut through the <span class="text-emerald-400">noise</span> in AI automation.
      </h1>
      <p class="text-lg sm:text-xl text-gray-400 max-w-xl leading-relaxed">
        We test the tools, skip the marketing, and tell you what <strong class="text-gray-200">actually works.</strong> Written by practitioners, not content farms.
      </p>
      <div class="mt-8">
        <a href="#articles" class="inline-block px-6 py-3 bg-emerald-500 text-gray-950 text-sm font-bold rounded-lg hover:bg-emerald-400 transition-colors">
          Browse All Reviews &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Articles -->
  <section id="articles" class="max-w-5xl mx-auto px-4 sm:px-6 py-12">

    <!-- Keyword filter row -->
    {allKeywords.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        {allKeywords.map(kw => (
          <span class="px-3 py-1 bg-[#161b26] border border-white/[0.08] rounded-full text-xs text-gray-400 hover:border-emerald-500/40 hover:text-emerald-400 transition-colors cursor-pointer">
            {kw}
          </span>
        ))}
      </div>
    )}

    {featured && (
      <div class="mb-10">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-4">Featured</p>
        <a
          href={`/articles/${featured.id}`}
          class="group block bg-[#161b26] border border-white/[0.08] rounded-xl p-6 sm:p-8 hover:border-emerald-500/30 hover:shadow-lg hover:shadow-emerald-500/5 transition-all"
        >
          <div class="flex flex-col sm:flex-row sm:items-start gap-6">
            <!-- Thumbnail -->
            <div class="shrink-0 w-full sm:w-[280px] h-44 bg-gradient-to-br from-[#1a1f2e] to-[#0f1117] rounded-lg flex items-center justify-center text-gray-600 text-xs font-medium overflow-hidden">
              <svg class="w-10 h-10 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
            </div>
            <!-- Content -->
            <div class="flex-1 min-w-0">
              <h2 class="text-2xl sm:text-3xl font-display text-gray-100 group-hover:text-emerald-400 transition-colors leading-snug mb-3">
                {featured.data.title}
              </h2>
              {featured.data.description && (
                <p class="text-gray-400 text-base leading-relaxed mb-4">{featured.data.description}</p>
              )}
              <div class="flex flex-wrap items-center gap-3 text-sm text-gray-500">
                {featured.data.date && (
                  <time datetime={featured.data.date.toISOString()}>
                    {featured.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                )}
                {featured.data.keywords && featured.data.keywords.slice(0, 3).map(kw => (
                  <span class="px-2 py-0.5 bg-white/[0.05] rounded text-xs text-gray-500">{kw}</span>
                ))}
              </div>
              <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-emerald-400 group-hover:text-emerald-300">
                Read &rarr;
              </span>
            </div>
          </div>
        </a>
      </div>
    )}

    {rest.length > 0 && (
      <div>
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-4">More Articles</p>
        <div class="grid sm:grid-cols-2 gap-5">
          {rest.map(article => (
            <a
              href={`/articles/${article.id}`}
              class="group block bg-[#161b26] border border-white/[0.08] rounded-xl p-5 hover:border-emerald-500/30 hover:shadow-lg hover:shadow-emerald-500/5 transition-all"
            >
              <div class="flex items-start gap-4">
                <!-- Thumbnail -->
                <div class="shrink-0 w-40 h-28 bg-gradient-to-br from-[#1a1f2e] to-[#0f1117] rounded-lg flex items-center justify-center text-gray-600 text-xs font-medium">
                  <svg class="w-8 h-8 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                </div>
                <!-- Content -->
                <div class="flex-1 min-w-0">
                  <h3 class="text-lg font-display text-gray-100 group-hover:text-emerald-400 transition-colors mb-2 leading-snug">
                    {article.data.title}
                  </h3>
                  {article.data.description && (
                    <p class="text-sm text-gray-400 leading-relaxed line-clamp-2">{article.data.description}</p>
                  )}
                  {article.data.date && (
                    <p class="mt-2 text-xs text-gray-600">
                      {article.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </p>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    {articles.length === 0 && (
      <p class="text-gray-500">No articles yet. Check back soon.</p>
    )}

  </section>
</BaseLayout>
