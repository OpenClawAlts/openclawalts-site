---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { fetchHeroImage } from '../../lib/unsplash';

export const prerender = true;

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content, headings } = await render(article);

// Resolve hero image: use frontmatter override if provided, otherwise fetch from Unsplash
let heroImage = null;
if (article.data.hero_image) {
  heroImage = {
    url: article.data.hero_image,
    alt: article.data.title,
    photographer: '',
    photographerUrl: '',
    unsplashUrl: '',
  };
} else {
  const searchCandidates = [...(article.data.keywords ?? []), article.data.title];
  for (const candidate of searchCandidates) {
    heroImage = await fetchHeroImage(candidate);
    if (heroImage) break;
  }
}

// Fetch per-tool images at build time
const [n8nImage, lindyImage, dynamiqImage] = await Promise.all([
  fetchHeroImage('workflow automation'),
  fetchHeroImage('productivity software'),
  fetchHeroImage('software automation'),
]);

const canonicalUrl = `https://openclawalts.com/articles/${article.id}`;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.data.title,
  "description": article.data.description ?? '',
  "datePublished": article.data.date?.toISOString() ?? '',
  "dateModified": article.data.date?.toISOString() ?? '',
  "author": {
    "@type": "Organization",
    "name": "OpenClaw Alt",
    "url": "https://openclawalts.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "OpenClaw Alt",
    "url": "https://openclawalts.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalUrl
  }
});

// Tool config for CTA cards
const tools = [
  {
    key: 'n8n',
    label: 'Best for self-hosting',
    name: 'n8n',
    description: 'Open-source, self-hostable, fully customizable.',
    cta: 'Try n8n Free →',
    href: '#',
    accent: false,
    image: n8nImage,
  },
  {
    key: 'lindy',
    label: 'Best for AI-first automation',
    name: 'Lindy',
    description: 'AI agents that act proactively. Fastest path to automation.',
    cta: 'Try Lindy →',
    href: '#',
    accent: true,
    image: lindyImage,
  },
  {
    key: 'getdynamiq',
    label: 'Best for enterprise / custom agents',
    name: 'GetDynamIQ',
    description: 'Custom AI agents built for complex business workflows.',
    cta: 'Get a Demo →',
    href: '#',
    accent: false,
    image: dynamiqImage,
  },
];
---

<ArticleLayout
  title={article.data.title}
  description={article.data.description}
  date={article.data.date}
  keywords={article.data.keywords}
  headings={headings}
  canonicalUrl={canonicalUrl}
  jsonLd={jsonLd}
  heroImage={heroImage}
>
  <!-- Top Pick card -->
  <div slot="top-pick" class="bg-indigo-50 border border-indigo-200 rounded-xl p-5">
    <p class="text-xs font-bold text-indigo-500 uppercase tracking-wider mb-2">⭐ Editor's Top Pick</p>
    <p class="text-base font-semibold text-gray-900 mb-1">Lindy — Best for AI-First Automation</p>
    <p class="text-sm text-gray-600 mb-4">Fastest path to working AI agents. Proactive, low-config, built for the modern stack.</p>
    <a href="#" class="inline-block px-5 py-2.5 bg-indigo-600 text-white text-sm font-bold rounded-lg hover:bg-indigo-700 transition-colors">
      Try Lindy →
    </a>
  </div>

  <Content />

  <!-- Inline CTA cards with tool images -->
  <div class="not-prose mt-10 space-y-4">
    {tools.map((tool) => (
      <div class={`bg-white border rounded-xl overflow-hidden flex flex-col sm:flex-row ${tool.accent ? 'border-indigo-200' : ''}`} style={tool.accent ? '' : 'border-color: #F3F4F6;'}>
        {tool.image && (
          <div class="sm:w-40 shrink-0 overflow-hidden bg-gray-100" style="min-height: 120px;">
            <img
              src={tool.image.url}
              alt={tool.image.alt}
              class="w-full h-full object-cover"
              style="min-height: 120px;"
              loading="lazy"
            />
          </div>
        )}
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 p-5 flex-1">
          <div>
            <p class={`text-xs font-semibold uppercase tracking-wider mb-0.5 ${tool.accent ? 'text-indigo-500' : 'text-gray-400'}`}>{tool.label}</p>
            <p class="text-base font-bold text-gray-900 mb-0.5">{tool.name}</p>
            <p class="text-sm text-gray-500">{tool.description}</p>
            {tool.image && (
              <p class="text-xs text-gray-300 mt-1">
                Photo: <a href={tool.image.unsplashUrl} target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-400">{tool.image.photographer}</a> / Unsplash
              </p>
            )}
          </div>
          <a href={tool.href} class="shrink-0 inline-block px-6 py-3 text-sm font-bold rounded-lg text-white transition-colors whitespace-nowrap" style="background-color: #4F46E5;">
            {tool.cta}
          </a>
        </div>
      </div>
    ))}
  </div>

  <!-- Bottom CTA summary grid -->
  <div class="not-prose mt-14 border-t border-gray-200 pt-10">
    <h2 class="text-2xl font-bold text-gray-900 mb-2">Ready to get started?</h2>
    <p class="text-gray-500 mb-8">Each tool below has a free trial or demo. Pick the one that fits your workflow.</p>

    <div class="grid gap-4 sm:grid-cols-3">
      {tools.map((tool) => (
        <div class={`border rounded-xl overflow-hidden flex flex-col ${tool.accent ? 'border-indigo-200 bg-indigo-50' : 'border-gray-200'}`}>
          {tool.image && (
            <div class="w-full overflow-hidden bg-gray-100" style="height: 140px;">
              <img
                src={tool.image.url}
                alt={tool.image.alt}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          )}
          <div class="p-5 flex flex-col flex-1">
            <p class={`text-xs font-semibold uppercase tracking-wider mb-1 ${tool.accent ? 'text-indigo-500' : 'text-gray-400'}`}>{tool.label}</p>
            <h3 class="text-lg font-bold text-gray-900 mb-2">{tool.name}</h3>
            <p class="text-sm text-gray-500 flex-1 mb-4">{tool.description}</p>
            {tool.image && (
              <p class="text-xs text-gray-300 mb-3">
                Photo: <a href={tool.image.unsplashUrl} target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-400">{tool.image.photographer}</a> / Unsplash
              </p>
            )}
            <a href={tool.href} class={`block w-full text-center px-4 py-3 text-white text-sm font-bold rounded-lg transition-colors ${tool.accent ? 'bg-indigo-600 hover:bg-indigo-700' : 'bg-gray-900 hover:bg-gray-700'}`}>
              {tool.cta}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>

</ArticleLayout>
