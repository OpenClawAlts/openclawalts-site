---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { fetchHeroImage } from '../../lib/unsplash';

export const prerender = true;

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content, headings } = await render(article);

// Resolve hero image: use frontmatter override if provided, otherwise fetch from Unsplash
let heroImage = null;
if (article.data.hero_image) {
  heroImage = {
    url: article.data.hero_image,
    alt: article.data.title,
    photographer: '',
    photographerUrl: '',
    unsplashUrl: '',
  };
} else {
  const searchCandidates = [...(article.data.keywords ?? []), article.data.title];
  for (const candidate of searchCandidates) {
    heroImage = await fetchHeroImage(candidate);
    if (heroImage) break;
  }
}

// Fetch per-tool images at build time (dynamic from frontmatter)
const toolImages: Record<string, Awaited<ReturnType<typeof fetchHeroImage>>> = {};
if (article.data.tools) {
  await Promise.all(
    article.data.tools.map(async (tool) => {
      toolImages[tool.key] = await fetchHeroImage(tool.image_query ?? tool.name);
    })
  );
}

const canonicalUrl = `https://openclawalts.com/articles/${article.id}`;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.data.title,
  "description": article.data.description ?? '',
  "datePublished": article.data.date?.toISOString() ?? '',
  "dateModified": article.data.date?.toISOString() ?? '',
  "author": {
    "@type": "Organization",
    "name": "OpenClaw Alt",
    "url": "https://openclawalts.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "OpenClaw Alt",
    "url": "https://openclawalts.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalUrl
  }
});
---

<ArticleLayout
  title={article.data.title}
  description={article.data.description}
  date={article.data.date}
  keywords={article.data.keywords}
  headings={headings}
  canonicalUrl={canonicalUrl}
  jsonLd={jsonLd}
  heroImage={heroImage}
>
  <!-- Top Pick card (dynamic from frontmatter) -->
  {article.data.top_pick && (
    <div slot="top-pick" style="background: #1a1f2e; border-left: 3px solid #00d4aa; border-radius: 8px; padding: 1.25rem;">
      <p style="font-size: 0.7rem; font-weight: 700; color: #00d4aa; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem;">⭐ Editor's Top Pick</p>
      <p style="font-size: 1rem; font-weight: 600; color: #f1f5f9; margin-bottom: 0.25rem;">{article.data.top_pick.name} — {article.data.top_pick.label}</p>
      <p style="font-size: 0.875rem; color: #94a3b8; margin-bottom: 1rem;">{article.data.top_pick.description}</p>
      <a href={article.data.top_pick.href} style="display: inline-block; padding: 0.5rem 1.25rem; background: #00d4aa; color: #0f1117; font-size: 0.875rem; font-weight: 700; border-radius: 4px; text-decoration: none;">
        Try {article.data.top_pick.name} →
      </a>
    </div>
  )}

  <Content />

  <!-- Inline CTA cards (from frontmatter tools) -->
  {article.data.tools && article.data.tools.length > 0 && (
    <div class="not-prose mt-10 space-y-4">
      {article.data.tools.map((tool) => {
        const img = toolImages[tool.key];
        return (
          <div style="background: #1a1f2e; border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; overflow: hidden;">
            <div class="flex flex-col sm:flex-row">
              {img && (
                <div class="sm:w-40 shrink-0 overflow-hidden bg-gray-800" style="min-height: 120px;">
                  <img src={img.url} alt={img.alt} class="w-full h-full object-cover" style="min-height: 120px;" loading="lazy" />
                </div>
              )}
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 p-5 flex-1">
                <div>
                  <p style={`font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.25rem; color: ${tool.accent ? '#00d4aa' : '#64748b'};`}>{tool.label}</p>
                  <p style="font-size: 1rem; font-weight: 700; color: #f1f5f9; margin-bottom: 0.25rem;">{tool.name}</p>
                  <p style="font-size: 0.875rem; color: #94a3b8;">{tool.description}</p>
                  {img && (
                    <p style="font-size: 0.7rem; color: #334155; margin-top: 0.5rem;">
                      Photo: <a href={img.unsplashUrl} target="_blank" rel="noopener noreferrer" style="text-decoration: underline; color: #475569;">{img.photographer}</a> / Unsplash
                    </p>
                  )}
                </div>
                <a href={tool.href} class="shrink-0 whitespace-nowrap" style="display: inline-block; padding: 0.75rem 1.5rem; background: #00d4aa; color: #0f1117; font-size: 0.875rem; font-weight: 700; border-radius: 4px; text-decoration: none;">
                  {tool.cta}
                </a>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  )}

  <!-- Bottom summary grid (from frontmatter tools) -->
  {article.data.tools && article.data.tools.length > 0 && (
    <div class="not-prose mt-14 pt-10" style="border-top: 1px solid rgba(255,255,255,0.08);">
      <h2 style="font-size: 1.5rem; font-weight: 700; color: #f1f5f9; margin-bottom: 0.5rem; font-family: 'Fraunces', serif;">Ready to get started?</h2>
      <p style="color: #64748b; margin-bottom: 2rem;">Each tool below has a free trial or demo.</p>
      <div class="grid gap-4 sm:grid-cols-3">
        {article.data.tools.map((tool) => {
          const img = toolImages[tool.key];
          return (
            <div style={`background: #1a1f2e; border: 1px solid ${tool.accent ? '#00d4aa33' : 'rgba(255,255,255,0.08)'}; border-radius: 12px; overflow: hidden; display: flex; flex-direction: column;`}>
              {img && (
                <div style="height: 140px; overflow: hidden; background: #0f1117;">
                  <img src={img.url} alt={img.alt} class="w-full h-full object-cover" loading="lazy" />
                </div>
              )}
              <div style="padding: 1.25rem; display: flex; flex-direction: column; flex: 1;">
                <p style={`font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.25rem; color: ${tool.accent ? '#00d4aa' : '#64748b'};`}>{tool.label}</p>
                <p style="font-size: 1.125rem; font-weight: 700; color: #f1f5f9; margin-bottom: 0.5rem;">{tool.name}</p>
                <p style="font-size: 0.875rem; color: #94a3b8; flex: 1; margin-bottom: 1rem;">{tool.description}</p>
                {img && (
                  <p style="font-size: 0.65rem; color: #334155; margin-bottom: 0.75rem;">
                    Photo: <a href={img.unsplashUrl} target="_blank" rel="noopener noreferrer" style="text-decoration: underline;">{img.photographer}</a> / Unsplash
                  </p>
                )}
                <a href={tool.href} style="display: block; text-align: center; padding: 0.75rem 1rem; background: #00d4aa; color: #0f1117; font-size: 0.875rem; font-weight: 700; border-radius: 4px; text-decoration: none;">
                  {tool.cta}
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  )}

</ArticleLayout>
